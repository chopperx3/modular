# ============================================================================
# Configuración de entorno para MODULAR OCR Backend
# ----------------------------------------------------------------------------
# Copia este archivo como `.env` y completa los valores antes de iniciar.
# El archivo `.env` NUNCA debe subirse al repositorio (ver .gitignore).
# ============================================================================

# API key de Groq (https://console.groq.com/keys)
# Se utiliza para el motor de OCR manuscrito basado en Llama 4 Scout Vision.
GROQ_API_KEY=tu_api_key_aqui

# Modelo Groq a utilizar (opcional, valor por defecto si se omite)
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Ruta absoluta al binario Tesseract en Windows
# En Linux/Mac normalmente se detecta automáticamente.
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Rate limit del API (requests por ventana / segundos de ventana)
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=60

# Origen permitido para CORS (separar con coma si son varios)
# Usa "*" SOLO en desarrollo. En producción especifica dominios.
CORS_ORIGINS=*
